{
  "name": "openclaw-quant-trading",
  "version": "0.1.0",
  "description": "OpenClaw Quant Trading Skills - 基于 Freqtrade 的量化交易技能包",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc -w",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "start": "node dist/index.js",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:cov": "jest --coverage --coverageReporters=text-lcov | coveralls",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "ci": "npm run lint && npm run typecheck && npm run build && npm test",
    "prepare": "husky install"
  },
  "keywords": [
    "openclaw",
    "quant",
    "trading",
    "freqtrade",
    "cryptocurrency",
    "backtesting",
    "strategy"
  ],
  "author": "OpenClaw Team",
  "license": "MIT",
  "type": "commonjs",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "ajv": "^8.17.1",
    "axios": "^1.6.0",
    "ccxt": "^4.3.14",
    "dotenv": "^16.4.5",
    "eventemitter3": "^5.0.1",
    "joi": "^17.12.0",
    "js-yaml": "^4.1.0",
    "p-retry": "^6.0.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "coveralls": "^3.1.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "fs-extra": "^11.3.4",
    "husky": "^9.0.10",
    "jest": "^29.7.0",
    "jest-transform-stub": "^2.0.0",
    "lint-staged": "^15.1.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/byteuser1977/openclaw-quant-trading.git"
  },
  "bugs": {
    "url": "https://github.com/byteuser1977/openclaw-quant-trading/issues"
  },
  "homepage": "https://github.com/byteuser1977/openclaw-quant-trading#readme"
}
